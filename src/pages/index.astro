---
import Mondrian from '../components/Mondrian.tsx';
import Homepage from '../components/Homepage.tsx';
import '../styles/index-home.css';
const REVEAL_ENABLED: boolean = false;


---


<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    <meta name="generator" content={Astro.generator} />
    <title>HE CARRIES WATER</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  </head>

  <body>

    <!-- Homepage sits behind everything, revealed as cells disappear -->
    <div class="underlayer">
      <!-- ═══════════════════════════════════════════════════
          REPLACE THIS WITH YOUR REAL HOMEPAGE CONTENT
          ═══════════════════════════════════════════════════ -->
      <Homepage />
    </div>

    <Mondrian live={REVEAL_ENABLED}/>

    <script type="module" src="/src/utils/mondrian.ts"></script>
  </body>
</html>
